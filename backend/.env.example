# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexmeet_db?retryWrites=true&w=majority
MONGODB_TEST_URI=mongodb://localhost:27017/nexmeet_test

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Email (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Cloudinary
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth (for future use)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Redis (for sessions/caching - optional)
REDIS_URL=redis://localhost:6379

# Frontend URLs
CLIENT_URL=http://localhost:3000
MOBILE_APP_URL=https://your-app.com

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FORMATS=jpg,jpeg,png,gif,mp4,webm
